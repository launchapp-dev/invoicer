{
  "mcpServers": {
    "ao": {
      "type": "stdio",
      "command": "/Users/samishukri/.local/bin/ao",
      "args": [
        "--project-root",
        "/Users/samishukri/brain",
        "mcp",
        "serve"
      ]
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    },
    "railway": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@railway/mcp-server"]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "gh-cli-mcp"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/record-mcp@latest", "--record", "--record-format", "webm", "--output-dir", ".ao/recordings"]
    },
    "rust-docs": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-rust-docs"]
    },
    "docker": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-docker"]
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "agent-memories": {
      "type": "stdio",
      "command": "node",
      "args": [
        "--experimental-strip-types",
        "/Users/samishukri/brain/repos/agent-memories/src/server.ts",
        "--db",
        "/Users/samishukri/brain/repos/agent-memories/data/agent-memories.db"
      ]
    }
  }
}
